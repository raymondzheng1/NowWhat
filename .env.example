# What Now? — environment variables (placeholders only; real secrets never committed)
# See CLAUDE.md "Env vars". Server-only secrets must never reach client code.

# --- Anthropic (server-side only) ---
# Powers ONLY /ask and /decode. The wizard, deadlines, drafts and help work without it.
ANTHROPIC_API_KEY=
# Optional: override the grounded-answer model (default claude-sonnet-4-6).
# Try claude-opus-4-8 (higher quality, dearer) or claude-haiku-4-5-20251001 (cheaper).
ANTHROPIC_MODEL=

# --- Upstash Redis (cost meter + rate limit; FAIL-CLOSED when unset in prod) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Some hosts inject the KV_* names instead — both are read (harness §15).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Cost guard ---
SESSION_CAP_USD=5
GLOBAL_DAILY_BUDGET_USD=50

# --- OCR (in-memory; optional; paste-text works without it) ---
# OCR_PROVIDER one of: "" (disabled — paste only), "gcv" (Google Cloud Vision)
OCR_PROVIDER=
OCR_API_KEY=

# --- Site ---
# Single source of truth for canonical/sitemap/robots/JSON-LD (harness §8).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Analytics (PII-safe; loader no-ops when unset) ---
NEXT_PUBLIC_GA_ID=

# --- Optional reminders / operator alerts ---
RESEND_API_KEY=
CRON_SECRET=

# --- Dev conveniences (gated to non-prod; fail-loud in prod) ---
# DEV_FAKE_NOW=2026-06-16T00:00:00.000Z
