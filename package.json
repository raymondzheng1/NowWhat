{
  "name": "what-now",
  "version": "0.1.0",
  "private": true,
  "description": "What Now? — a free, login-free web app that helps people understand and respond to an adverse government decision. Information, not advice. Grounded-or-silent.",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/build-corpus.mjs && next build",
    "start": "next start",
    "lint": "eslint . && tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "build:corpus": "node scripts/build-corpus.mjs",
    "corpus:check": "node scripts/corpus-check.mjs",
    "no-advice:check": "node scripts/no-advice-check.mjs",
    "no-ai-mentions:check": "node scripts/no-ai-mentions-check.mjs",
    "reading-level:check": "node scripts/reading-level-check.mjs",
    "links:check": "node scripts/links-check.mjs",
    "seo:check": "node scripts/seo-check.mjs",
    "launch:check": "node scripts/launch-check.mjs",
    "verify": "node scripts/build-corpus.mjs && node scripts/corpus-check.mjs && node scripts/no-advice-check.mjs && node scripts/no-ai-mentions-check.mjs && node scripts/reading-level-check.mjs && node scripts/links-check.mjs && node scripts/seo-check.mjs && node scripts/launch-check.mjs && eslint . && tsc --noEmit && vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@upstash/redis": "^1.34.3",
    "@vercel/analytics": "^1.4.1",
    "gray-matter": "^4.0.3",
    "next": "^15.1.6",
    "next-intl": "^3.26.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
